# =============================================
# wave-ver2.0 - .gitignore
# =============================================

# 환경 변수 파일
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 노드 모듈
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Vercel 빌드 파일
.vercel/

# 에디터 및 IDE 관련
.vscode/
.idea/
*.swp
*.swo
*~

# 운영체제 관련
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# 로그 파일
*.log
logs/

# 임시 파일
*.tmp
*.temp

# 백업 파일
*.bak
*.backup

# 캐시 파일
.cache/
*.cache

# 빌드 디렉토리
dist/
build/

# 테스트 커버리지
coverage/

# Supabase 로컬 설정 (민감한 정보 포함)
supabase/.env

# 개발 중 임시 파일들
test-*
debug-*
temp-* 